{
  "name": "planlock",
  "version": "0.1.0-alpha.0",
  "description": "Real-time plan-drift watchdog for Claude Code. Keeps Claude honest to its own plan.",
  "type": "module",
  "bin": {
    "planlock": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "plan-mode",
    "drift-detection",
    "hooks",
    "ai-agents"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "micromatch": "^4.0.8",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.17.6",
    "fast-check": "^3.23.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
